# ============================================================
# BuffetPro — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ── Database ────────────────────────────────────────────────
# MySQL connection string used by Prisma
DATABASE_URL="mysql://user:password@localhost:3306/buffetpro"

# ── NextAuth.js ─────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"
# The public URL of the web app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook secret from `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs for your subscription plans
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PROFESSIONAL="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="BuffetPro"

# ── Email (optional) ────────────────────────────────────────
# SMTP settings for transactional emails
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@example.com"
SMTP_PASSWORD="smtp-password"
SMTP_FROM="BuffetPro <noreply@example.com>"

# ── AI / Translation (Phase 3) ──────────────────────────────
OPENAI_API_KEY="sk-..."
DEEPL_API_KEY="..."
