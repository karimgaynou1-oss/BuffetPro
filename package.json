{
  "name": "buffetpro",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate --filter=@buffetpro/db",
    "db:migrate": "turbo run db:migrate --filter=@buffetpro/db",
    "db:push": "turbo run db:push --filter=@buffetpro/db",
    "db:seed": "turbo run db:seed --filter=@buffetpro/db",
    "db:studio": "turbo run db:studio --filter=@buffetpro/db",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "prettier": "^3.2.4",
    "turbo": "^1.12.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@8.15.1"
}
